# Generated by Cargo
# will have compiled files and executables
/target
/docker
.DS_Store
.env
# These are backup files generated by rustfmt
**/*.rs.bk

# Claude Code local config/session state — not relevant to the app
.claude/
CLAUDE.local.md

# Local deploy config (server host/path) — see scripts/.env.deploy.example
scripts/.env.deploy
scripts/deploy.sh

# Internal working notes — not meant for a public repo
DESIGN_PROGRESS.md
AGENTS.md

# One-off SQL fixes run directly against the hosted Supabase project — too
# much detail about the live schema/security posture to be comfortable
# public, even after the fix itself is live either way.
scripts/*.sql

# Marketing site (blackserverbook.com) — separate static site, not part of the app
/marketing/

